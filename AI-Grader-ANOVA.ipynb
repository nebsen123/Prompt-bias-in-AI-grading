   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import scipy.stats as stats\n",
    "import pingouin as pg\n",
    "import numpy as np"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "7defc7a0",
   "metadata": {},
   "source": [
    "**Loading of data**\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "c0c462f9",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Replace with our file path\n",
    "df = pd.read_csv(\"ai_grading_experiment.csv\")\n",
    "\n",
    "# Required columns:\n",
    "required_columns = [\n",
    "    \"answer_key_id\",\n",
    "    \"true_mistakes\",\n",
    "    \"prompt_type\",\n",
    "    \"ai_estimated_mistakes\"\n",
    "]\n",
    "\n",
    "# Dependent variable: AI grading error\n",
    "df[\"ai_error\"] = df[\"ai_estimated_mistakes\"] - df[\"true_mistakes\"]\n",
    "df["Absolute_error"] = abs(df["ai_estimated_mistakes"]-df["true_mistakes"])\n",
    "df[\"true_mistakes\"] = df[\"true_mistakes\"].astype(\"category\")\n",
    "df[\"prompt_type\"] = df[\"prompt_type\"].astype(\"category\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "31c41e96",
   "metadata": {},
   "source": [
    "**2-way Mixed ANOVA**"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4b832477",
   "metadata": {},
   "source": [
    "Assumptions: Homogeneity of variance, Independence of observations, Normally-distributed dependent variable "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "1dcfa923",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "=============\n",
      "ANOVA SUMMARY\n",
      "=============\n",
      "\n",
      "Source              SS    DF1    DF2       MS        F    p_unc    np2      eps\n",
      "-------------  -------  -----  -----  -------  -------  -------  -----  -------\n",
      "true_mistakes   49.206     15    464    3.280    3.732    0.000  0.108  nan\n",
      "prompt_type    547.196      4   1856  136.799  229.441    0.000  0.331    0.993\n",
      "Interaction     67.004     60   1856    1.117    1.873    0.000  0.057  nan\n",
      "\n"
     ]
    },
    {
     "data": {
      "image/png": "",
